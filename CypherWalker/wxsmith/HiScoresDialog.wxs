<?xml version="1.0" encoding="utf-8" ?>
<wxsmith>
	<object class="wxDialog" name="HiScoresDialog">
		<title>High scores</title>
		<centered>1</centered>
		<id_arg>0</id_arg>
		<object class="wxFlexGridSizer" variable="FlexGridSizer1" member="no">
			<rows>3</rows>
			<object class="sizeritem">
				<object class="wxStaticText" name="ID_HALLOFFAMESTATICTEXT" variable="HallOfFameStaticText" member="yes">
					<label>Hall of Fame</label>
					<font>
						<weight>bold</weight>
					</font>
				</object>
				<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
				<border>5</border>
				<option>1</option>
			</object>
			<object class="sizeritem">
				<object class="wxFlexGridSizer" variable="FlexGridSizer2" member="no">
					<cols>2</cols>
					<rows>5</rows>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_NAMESTATICTEXT1" variable="NameStaticText1" member="yes">
							<label>Name 1</label>
							<minsize>300,14</minsize>
							<maxsize>-1,14</maxsize>
							<style>wxST_NO_AUTORESIZE</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_SCORESTATICTEXT1" variable="ScoreStaticText1" member="yes">
							<label>0</label>
							<minsize>20,14</minsize>
							<maxsize>20,14</maxsize>
							<style>wxST_NO_AUTORESIZE|wxALIGN_RIGHT</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_NAMESTATICTEXT2" variable="NameStaticText2" member="yes">
							<label>Name 2</label>
							<minsize>300,14</minsize>
							<maxsize>-1,14</maxsize>
							<style>wxST_NO_AUTORESIZE</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_SCORESTATICTEXT2" variable="ScoreStaticText2" member="yes">
							<label>0</label>
							<minsize>20,14</minsize>
							<maxsize>20,14</maxsize>
							<style>wxST_NO_AUTORESIZE|wxALIGN_RIGHT</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_NAMESTATICTEXT3" variable="NameStaticText3" member="yes">
							<label>Name 3</label>
							<minsize>300,14</minsize>
							<maxsize>-1,14</maxsize>
							<style>wxST_NO_AUTORESIZE</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_SCORESTATICTEXT3" variable="ScoreStaticText3" member="yes">
							<label>0</label>
							<minsize>20,14</minsize>
							<maxsize>20,14</maxsize>
							<style>wxST_NO_AUTORESIZE|wxALIGN_RIGHT</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_NAMESTATICTEXT4" variable="NameStaticText4" member="yes">
							<label>Name 4</label>
							<minsize>300,14</minsize>
							<maxsize>-1,14</maxsize>
							<style>wxST_NO_AUTORESIZE</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_SCORESTATICTEXT4" variable="ScoreStaticText4" member="yes">
							<label>0</label>
							<minsize>20,14</minsize>
							<maxsize>20,14</maxsize>
							<style>wxST_NO_AUTORESIZE|wxALIGN_RIGHT</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_NAMESTATICTEXT5" variable="NameStaticText5" member="yes">
							<label>Name 5</label>
							<minsize>300,14</minsize>
							<maxsize>-1,14</maxsize>
							<style>wxST_NO_AUTORESIZE</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxStaticText" name="ID_SCORESTATICTEXT5" variable="ScoreStaticText5" member="yes">
							<label>0</label>
							<minsize>20,14</minsize>
							<maxsize>20,14</maxsize>
							<style>wxST_NO_AUTORESIZE|wxALIGN_RIGHT</style>
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5</border>
						<option>1</option>
					</object>
				</object>
				<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
				<border>5</border>
				<option>1</option>
			</object>
			<object class="sizeritem">
				<object class="wxFlexGridSizer" variable="FlexGridSizer3" member="no">
					<cols>2</cols>
					<object class="sizeritem">
						<object class="wxButton" name="wxID_OK" variable="OKButton" member="yes">
							<label>OK</label>
							<default>1</default>
							<handler function="OnOKButtonClick" entry="EVT_BUTTON" />
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5d</border>
						<option>1</option>
					</object>
					<object class="sizeritem">
						<object class="wxButton" name="ID_ERASEALLBUTTON" variable="EraseAllButton" member="yes">
							<label>&amp;Erase all</label>
							<handler function="OnEraseAllButtonClick" entry="EVT_BUTTON" />
						</object>
						<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
						<border>5d</border>
						<option>1</option>
					</object>
				</object>
				<flag>wxALL|wxALIGN_CENTER_HORIZONTAL|wxALIGN_CENTER_VERTICAL</flag>
				<border>5</border>
				<option>1</option>
			</object>
		</object>
	</object>
</wxsmith>
