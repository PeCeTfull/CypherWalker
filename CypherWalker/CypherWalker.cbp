<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="CypherWalker" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/cyphwalk" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-g" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/msw" />
					<Add directory="include" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/msw" />
				</ResourceCompiler>
				<Linker>
					<Add library="libwxmsw28.a" />
					<Add library="libwxpng.a" />
					<Add library="libwxjpeg.a" />
					<Add library="libwxtiff.a" />
					<Add library="libwxzlib.a" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/cyphwalk" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-Os" />
					<Add option="-O2" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/msw" />
					<Add directory="include" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib/msw" />
				</ResourceCompiler>
				<Linker>
					<Add option="-s" />
					<Add library="libwxmsw28.a" />
					<Add library="libwxpng.a" />
					<Add library="libwxjpeg.a" />
					<Add library="libwxtiff.a" />
					<Add library="libwxzlib.a" />
					<Add directory="E:/wxWidgets-2.8.12/lib/gcc_lib" />
				</Linker>
				<ExtraCommands>
					<Add after='E:\Moje programy\upx\upx &quot;$(PROJECTDIR)$(TARGET_OUTPUT_DIR)cyphwalk.exe&quot;' />
				</ExtraCommands>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-pipe" />
			<Add option="-mthreads" />
			<Add option='[[if (GetCompilerFactory().GetCompilerVersionString(_T(&quot;gcc&quot;)) &gt;= _T(&quot;4.8.0&quot;)) print(_T(&quot;-Wno-unused-local-typedefs&quot;));]]' />
			<Add option="-D__GNUWIN32__" />
			<Add option="-D__WXMSW__" />
			<Add directory="E:/wxWidgets-2.8.12/include" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="E:/wxWidgets-2.8.12/include" />
		</ResourceCompiler>
		<Linker>
			<Add option="-mthreads" />
			<Add library="libkernel32.a" />
			<Add library="libuser32.a" />
			<Add library="libgdi32.a" />
			<Add library="libwinspool.a" />
			<Add library="libcomdlg32.a" />
			<Add library="libadvapi32.a" />
			<Add library="libshell32.a" />
			<Add library="libole32.a" />
			<Add library="liboleaut32.a" />
			<Add library="libuuid.a" />
			<Add library="libcomctl32.a" />
			<Add library="libwsock32.a" />
			<Add library="libodbc32.a" />
			<Add library="libwinmm.a" />
		</Linker>
		<ExtraCommands>
			<Add after='xcopy /e /y &quot;$(PROJECTDIR)common\*&quot; &quot;$(PROJECTDIR)$(TARGET_OUTPUT_DIR)&quot;' />
			<Mode after="always" />
		</ExtraCommands>
		<Unit filename="CypherWalkerApp.cpp" />
		<Unit filename="CypherWalkerApp.h" />
		<Unit filename="CypherWalkerMain.cpp" />
		<Unit filename="CypherWalkerMain.h" />
		<Unit filename="EnterNameDialog.cpp" />
		<Unit filename="EnterNameDialog.h" />
		<Unit filename="HiScoresDialog.cpp" />
		<Unit filename="HiScoresDialog.h" />
		<Unit filename="OptionsDialog.cpp" />
		<Unit filename="OptionsDialog.h" />
		<Unit filename="include/ConfigFile.h" />
		<Unit filename="include/HiScoresFile.h" />
		<Unit filename="include/wxImagePanel.h" />
		<Unit filename="include/wxTranslationHelper.h" />
		<Unit filename="resource.rc">
			<Option compilerVar="WINDRES" />
		</Unit>
		<Unit filename="src/ConfigFile.cpp" />
		<Unit filename="src/HiScoresFile.cpp" />
		<Unit filename="src/wxTranslationHelper.cpp" />
		<Unit filename="wxsmith/CypherWalkerdialog.wxs" />
		<Unit filename="wxsmith/EnterNameDialog.wxs" />
		<Unit filename="wxsmith/HiScoresDialog.wxs" />
		<Unit filename="wxsmith/OptionsDialog.wxs" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
			<lib_finder disable_auto="1" />
			<wxsmith version="1">
				<gui name="wxWidgets" src="CypherWalkerApp.cpp" main="CypherWalkerDialog" init_handlers="necessary" language="CPP" />
				<resources>
					<wxDialog wxs="wxsmith/CypherWalkerdialog.wxs" src="CypherWalkerMain.cpp" hdr="CypherWalkerMain.h" fwddecl="0" i18n="1" name="CypherWalkerDialog" language="CPP" />
					<wxDialog wxs="wxsmith/HiScoresDialog.wxs" src="HiScoresDialog.cpp" hdr="HiScoresDialog.h" fwddecl="0" i18n="1" name="HiScoresDialog" language="CPP" />
					<wxDialog wxs="wxsmith/EnterNameDialog.wxs" src="EnterNameDialog.cpp" hdr="EnterNameDialog.h" fwddecl="0" i18n="1" name="EnterNameDialog" language="CPP" />
					<wxDialog wxs="wxsmith/OptionsDialog.wxs" src="OptionsDialog.cpp" hdr="OptionsDialog.h" fwddecl="0" i18n="1" name="OptionsDialog" language="CPP" />
				</resources>
			</wxsmith>
		</Extensions>
	</Project>
</CodeBlocks_project_file>
